# Единый стиль для всех редакторов/IDE (VS Code, PyCharm) — чтобы код от alex и
# step выглядел одинаково и не плодил formatting-diff на CI. Источник правды по
# форматированию — ruff (line-length 100, py312); editorconfig дублирует базовое.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
# В Markdown два пробела в конце строки — значимый перенос.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
