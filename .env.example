# =========================================================================
#  NovaPostBot — пример переменных окружения. Скопируй в .env и заполни.
#  .env в git НЕ попадает (см. .gitignore). Реальные секреты сюда не пишем.
# =========================================================================

# --- Telegram ---
BOT_TOKEN=

# --- PostgreSQL (Neon) ---
# Приложение ходит через ПУЛЕР (-pooler хост). Для asyncpg за PgBouncer
# в config.py выставляется statement_cache_size=0.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/novapostbot?ssl=require
# Alembic-миграции — ПРЯМОЙ (non-pooled) коннект (без -pooler).
DATABASE_URL_DIRECT=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/novapostbot?ssl=require

# --- Redis (FSM / кэш справочников НП) ---
REDIS_URL=redis://redis:6379/0

# --- Шифрование ключей НП (Fernet) ---
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Google Sheets (только склад) ---
# Путь к JSON service-account (файл кладём в ./secrets/, он в .gitignore).
GOOGLE_SA_JSON=./secrets/service-account.json
SHEETS_STOCK_BOOK_ID=
SHEETS_INTAKE_BOOK_ID=

# --- Роли (Telegram ID через запятую) ---
OWNER_TELEGRAM_IDS=
DEV_TELEGRAM_IDS=

# --- Прочее ---
TIMEZONE=Europe/Kyiv
LOG_LEVEL=INFO
